<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('images/favi.png') }}">
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
              rel="stylesheet"
              integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
              crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
              rel="stylesheet">
        <link href="{{ asset('css/styles.css') }}" rel="stylesheet">
    {% endblock %}
</head>
<body class="pt-5">
<header class="navbar navbar-expand-lg fixed-top bg-white border-bottom px-3 shadow-sm">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand fw-bold text-primary" href="{{ url('note_index') }}">
            <i class="bi bi-check2-square"></i> Test Driven Notes
        </a>

        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <nav class="d-none d-md-flex gap-3 border-start border-end px-4">
            <a href="{{ url('note_index') }}" class="text-dark text-decoration-none small fw-semibold">
                <i class="bi bi-journal-text"></i> {{ 'title.note_list'|trans }}
            </a>
            <a href="{{ url('category_index') }}" class="text-dark text-decoration-none small fw-semibold">
                <i class="bi bi-collection"></i> {{ 'title.category_list'|trans }}
            </a>
            <a href="{{ url('tag_index') }}" class="text-dark text-decoration-none small fw-semibold">
                <i class="bi bi-tags"></i> {{ 'title.tag_list'|trans }}
            </a>
            <a href="{{ url('todo_index') }}" class="text-primary text-decoration-none small fw-bold">
                <i class="bi bi-list-check"></i> {{ 'title.todo_list'|trans }}
            </a>
        </nav>
        {% endif %}

        <div class="d-flex align-items-center gap-3">
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}

                <div class="d-flex align-items-center gap-2 border-end pe-3">
                    {% if app.user.avatar.filename is defined and app.user.avatar.filename|length %}
                        <img class="rounded-circle border"
                             src="{{ asset(avatars_directory ~ app.user.avatar.filename) }}"
                             alt="avatar"
                             style="width: 35px; height: 35px; object-fit: cover;">
                    {% else %}
                        <i class="bi bi-person-circle fs-4 text-secondary"></i>
                    {% endif %}

                    <div class="d-none d-sm-block">
                        <div class="small fw-bold lh-1">{{ app.user.email }}</div>
                        <a href="{{ url('user_profile') }}" class="text-primary text-decoration-none" style="font-size: 0.75rem;">
                            {{ 'label.my_profile'|trans|default('Mój profil') }}
                        </a>
                    </div>
                </div>

                <div class="ps-1">
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ url('user_index') }}" class="btn btn-outline-secondary btn-sm me-1" title="{{ 'title.user_list'|trans }}">
                            <i class="bi bi-people"></i>
                        </a>
                    {% endif %}
                    <a href="{{ url('app_logout') }}" class="btn btn-outline-danger btn-sm" title="{{ 'action.logout'|trans }}">
                        <i class="bi bi-box-arrow-right"></i> {{ 'action.logout'|trans }}
                    </a>
                </div>

            {% else %}
                <a href="{{ url('app_login') }}" class="btn btn-primary btn-sm">
                    <i class="bi bi-box-arrow-in-right"></i> {{ 'action.login'|trans }}
                </a>
            {% endif %}
        </div>
    </div>
</header>
<main role="main" class="mt-3 pt-3">
    <div class="container-fluid px-4">
        {% include 'default/_flash_messages.html.twig' %}

        <div class="row">
            <div class="col-12">
                {% block body %}
                {% endblock %}
            </div>
        </div>
    </div>
</main>
    {% block javascripts %}
        {# {% block importmap %}{{ importmap('app') }}{% endblock %} #}
        <script
            src="https://code.jquery.com/jquery-3.7.1.slim.min.js"
            integrity="sha256-kmHvs0B+OpCW5GVHUNjv9rOmY0IvSIRcf7zGUDTDQM8="
            crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
                integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
                crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
                crossorigin="anonymous"></script>
    {% endblock %}
</body>
</html>
