{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.note_details'|trans({'%id%': note.id|default('')}) }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.note_details'|trans({'%id%': note.id|default('')}) }}</h1>

    {% if note is defined and note is not null %}
        <dl class="dl-horizontal">
            <dt>{{ 'label.id'|trans }}</dt>
            <dd>{{ note.id }}</dd>

            <dt>{{ 'label.status'|trans }}</dt>
            <dd>
                <span class="badge {{ note.status.value == 1 ? 'bg-primary' : 'bg-success' }}">
                    {{ note.status.label|trans }}
                </span>
            </dd>

            <dt>{{ 'label.created_at'|trans }}</dt>
            <dd>{{ note.createdAt|format_date('long') }}</dd>

            <dt>{{ 'label.updated_at'|trans }}</dt>
            <dd>{{ note.updatedAt|format_date('long') }}</dd>

            <dt>{{ 'label.title'|trans }}</dt>
            <dd><strong>{{ note.title }}</strong></dd>

            <dt>{{ 'label.author'|trans }}</dt>
            <dd>
                {% if note.author is defined and note.author is not null %}
                    <i class="bi bi-person"></i> {{ note.author.email }}
                {% else %}
                    <span class="text-muted">{{ 'label.none'|trans }}</span>
                {% endif %}
            </dd>

            <dt>{{ 'label.tags'|trans }}</dt>
            <dd>
                {% if note.tags is not empty %}
                    {% for tag in note.tags %}
                        <span class="text-dark">{{ tag.title }}</span>{{ not loop.last ? ', ' : '' }}
                    {% endfor %}
                {% else %}
                    {{ 'label.none'|trans }}
                {% endif %}
            </dd>

            <dt>{{ 'label.category'|trans }}</dt>
            <dd>{{  note.category.title }}</dd>

            <dt>{{ 'label.comment'|trans }}</dt>
            <dd>
                <div class="border rounded p-3 bg-light">
                    {% if note.comment is not empty %}
                        {{ note.comment|markdown_to_html }}
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </div>
            </dd>
        </dl>

        <div class="mt-3">
            <a href="{{ url('note_index') }}" class="btn btn-outline-primary" title="{{ 'action.back_to_list'|trans }}">
                {{ 'action.back_to_list'|trans }}
            </a>

            {% if is_granted('EDIT', note) %}
                <a href="{{ url('note_edit', {id: note.id}) }}" class="btn btn-warning">
                    {{ 'action.edit'|trans }}
                </a>
            {% endif %}
        </div>
    {% else %}
        {% include 'default/_single_alert_message.html.twig' with {
            type: 'warning',
            message: 'message.record_not_found'|trans
        } %}
    {% endif %}
{% endblock %}
