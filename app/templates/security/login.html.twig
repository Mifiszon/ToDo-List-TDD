{% extends 'base.html.twig' %}

{% block title %}{{ 'action.login'|trans }}{% endblock %}

{% block body %}
    <div class="container d-flex align-items-center justify-content-center min-vh-100">

        <div class="card shadow-lg border-0 rounded-4" style="width: 100%; max-width: 420px;">

            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <h1 class="h4 fw-bold mb-1">
                        {{ 'action.login'|trans }}
                    </h1>
                    <small class="text-muted">
                        Zaloguj się do swojego konta
                    </small>
                </div>

                {% if error %}
                    <div class="alert alert-danger small py-2">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}">

                    <div class="mb-3">
                        <label for="username" class="form-label">
                            {{ 'label.email'|trans }}
                        </label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="_username"
                            id="username"
                            class="form-control form-control-lg"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">
                            {{ 'label.password'|trans }}
                        </label>
                        <input
                            type="password"
                            name="_password"
                            id="password"
                            class="form-control form-control-lg"
                            autocomplete="current-password"
                            required
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="d-grid mt-4">
                        <button class="btn btn-primary btn-lg shadow-sm" type="submit">
                            {{ 'action.login'|trans }}
                        </button>
                    </div>

                </form>

                <hr class="my-4">

                <div class="text-center">
                    <small class="text-muted">
                        {{ 'message.no_account'|trans }}
                    </small>
                    <div>
                        <a href="{{ path('app_register') }}" class="fw-semibold text-decoration-none">
                            {{ 'action.register'|trans }}
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
{% endblock %}
