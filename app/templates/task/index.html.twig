{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.task_list'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.task_list'|trans }}</h1>

    <div class="mb-3">
        <a href="{{ url('task_create') }}" class="btn btn-success">
            <i class="bi bi-plus-lg"></i> {{ 'action.create'|trans }}
        </a>
    </div>

    {% if pagination is defined and pagination.items|length %}

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'label.id'|trans, 'task.id') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'label.created_at'|trans, 'task.createdAt') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'label.updated_at'|trans, 'task.updatedAt') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'label.title'|trans, 'task.title') }}</th>
                <th>
                    {{ knp_pagination_sortable(pagination, 'label.author'|trans, 'author.email') }}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ url('user_index') }}" title="{{ 'title.user_list'|trans }}" class="ms-1">
                            <i class="bi bi-people-fill"></i>
                        </a>
                    {% endif %}</th>
                <th>
                    {% if task.tags is defined and task.tags|length %}
                        {% for tag in task.tags %}
                            <a class="btn btn-outline-primary"
                               href="{{ url('task_index', {'tagId' : tag.id, 'statusId' : task.status.value}) }}"
                               title="{{ tag.title }}">
                                {{ tag.title }}
                            </a>
                        {% endfor %}
                    {% else %}
                        &nbsp;
                    {% endif %}
                </th>
                <th>
                    <a class="btn btn-outline-primary"
                       href="{{ url('task_index', {'categoryId' : task.category.id, 'statusId' : task.status.value}) }}"
                       title="{{ task.category.title }}">
                        {{ task.category.title }}
                    </a>
                </th>
                <th>{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for task in pagination.items %}
                <tr>
                    <td>{{ task.id }}</td>
                    <td>{{ task.createdAt|format_date('long') }}</td>
                    <td>{{ task.updatedAt|format_date('long') }}</td>
                    <td>{{ task.title }}</td>
                    <td>{{ task.author.email|default('-') }}</td>
                    <td>
                        {% if task.tags is not empty %}
                            {{ task.tags|map(t => t.title)|join(', ') }}
                        {% else %}
                            <span class="text-muted">-</span>
                        {% endif %}
                    </td>
                    <td>{{ task.category.title }}</td>
                    <td>
                        <div class="btn-group" role="group">
                            {% if is_granted('TASK_VIEW', task) %}
                                <a class="btn btn-primary" href="{{ url('task_view', {id: task.id}) }}" title="{{ 'action.view'|trans }}">
                                    {{ 'action.view'|trans }}
                                </a>
                            {% endif %}
                            {% if is_granted('TASK_EDIT', task) %}
                                <a class="btn btn-warning" href="{{ url('task_edit', {id: task.id}) }}" title="{{ 'action.edit'|trans }}">
                                    {{ 'action.edit'|trans }}
                                </a>
                            {% endif %}
                            {% if is_granted('TASK_DELETE', task) %}
                                <a class="btn btn-danger" href="{{ url('task_delete', {id: task.id}) }}" title="{{ 'action.delete'|trans }}">
                                    {{ 'action.delete'|trans }}
                                </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

    {% else %}
        {% include 'default/_single_alert_message.html.twig' with {
            type: 'warning',
            message: 'message.empty_list'|trans
        } %}
    {% endif %}
{% endblock %}
