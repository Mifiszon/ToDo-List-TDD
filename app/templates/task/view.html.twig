{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.task_details'|trans({'%id%': task.id|default('')}) }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.task_details'|trans({'%id%': task.id|default('')}) }}</h1>

    {% if task is defined and task is not null %}
        <dl class="dl-horizontal">
            <dt>{{ 'label.id'|trans }}</dt>
            <dd>{{ task.id }}</dd>

            <dt>{{ 'label.status'|trans }}</dt>
            <dd>
                <span class="badge {{ task.status.value == 1 ? 'bg-primary' : 'bg-success' }}">
                    {{ task.status.label|trans }}
                </span>
            </dd>

            <dt>{{ 'label.created_at'|trans }}</dt>
            <dd>{{ task.createdAt|format_date('long') }}</dd>

            <dt>{{ 'label.updated_at'|trans }}</dt>
            <dd>{{ task.updatedAt|format_date('long') }}</dd>

            <dt>{{ 'label.title'|trans }}</dt>
            <dd><strong>{{ task.title }}</strong></dd>

            <dt>{{ 'label.author'|trans }}</dt>
            <dd>
                {% if task.author is defined and task.author is not null %}
                    <i class="bi bi-person"></i> {{ task.author.email }}
                {% else %}
                    <span class="text-muted">{{ 'label.none'|trans }}</span>
                {% endif %}
            </dd>

            <dt>{{ 'label.tags'|trans }}</dt>
            <dd>
                {% if task.tags is not empty %}
                    {% for tag in task.tags %}
                        <span class="text-dark">{{ tag.title }}</span>{{ not loop.last ? ', ' : '' }}
                    {% endfor %}
                {% else %}
                    {{ 'label.none'|trans }}
                {% endif %}
            </dd>

            <dt>{{ 'label.category'|trans }}</dt>
            <dd>{{  task.category.title }}</dd>

            <dt>{{ 'label.comment'|trans }}</dt>
            <dd>
                <div class="border rounded p-3 bg-light">
                    {% if task.comment is not empty %}
                        {{ task.comment|markdown_to_html }}
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </div>
            </dd>
        </dl>

        <div class="mt-3">
            <a href="{{ url('task_index') }}" class="btn btn-outline-primary" title="{{ 'action.back_to_list'|trans }}">
                {{ 'action.back_to_list'|trans }}
            </a>

            {% if is_granted('EDIT', task) %}
                <a href="{{ url('task_edit', {id: task.id}) }}" class="btn btn-warning">
                    {{ 'action.edit'|trans }}
                </a>
            {% endif %}
        </div>
    {% else %}
        {% include 'default/_single_alert_message.html.twig' with {
            type: 'warning',
            message: 'message.record_not_found'|trans
        } %}
    {% endif %}
{% endblock %}
