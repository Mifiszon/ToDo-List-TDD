{% extends 'base.html.twig' %}

{% block title %}{{ 'title.todo_view'|trans({'%id%': todo.id}) }}{% endblock %}

{% block body %}
    <h1>{{ 'title.todo_view'|trans({'%id%': todo.id}) }}</h1>

    <table class="table table-striped">
        <tbody>
        <tr>
            <th>{{ 'label.id'|trans }}</th>
            <td>{{ todo.id }}</td>
        </tr>
        <tr>
            <th>{{ 'label.title'|trans }}</th>
            <td>{{ todo.title }}</td>
        </tr>
        <tr>
            <th>{{ 'label.status'|trans }}</th>
            <td>
                    <span class="badge {{ todo.isDone ? 'bg-success' : 'bg-warning' }}">
                        {{ (todo.isDone ? 'label.status_done' : 'label.status_active')|trans }}
                    </span>
            </td>
        </tr>
        <tr>
            <th>{{ 'label.author'|trans }}</th>
            <td>{{ todo.author.email }}</td>
        </tr>
        </tbody>
    </table>

    <div class="mt-3">
        <a href="{{ path('todo_index') }}" class="btn btn-outline-secondary">
            {{ 'action.back_to_list'|trans }}
        </a>

        {% if is_granted('TODO_EDIT', todo) %}
            <a href="{{ path('todo_edit', {'id': todo.id}) }}" class="btn btn-warning">
                {{ 'action.edit'|trans }}
            </a>
        {% endif %}

        {% if is_granted('TODO_DELETE', todo) %}
            <div class="d-inline-block">
                {{ include('todo/delete.html.twig') }}
            </div>
        {% endif %}
    </div>
{% endblock %}
