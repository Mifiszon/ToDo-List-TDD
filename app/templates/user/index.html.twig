{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.user_list'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.user_list'|trans }}</h1>

    <div class="mb-3">
        <a href="{{ url('user_create') }}" class="btn btn-success">
            <i class="bi bi-person-plus"></i> {{ 'action.create'|trans }}
        </a>
    </div>

    {% if pagination is defined and pagination.items|length %}

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'label.id'|trans, 'user.id') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'label.email'|trans, 'user.email') }}</th>
                <th>{{ 'label.roles'|trans }}</th>
                <th>{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for user in pagination.items %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% for role in user.roles %}
                            <span class="badge bg-secondary">{{ role }}</span>
                        {% endfor %}
                    </td>
                    <td class="text-nowrap">
                        <div class="btn-group" role="group">
                            <a class="btn btn-primary" href="{{ url('user_view', {id: user.id}) }}" title="{{ 'action.view'|trans }}">
                                {{ 'action.view'|trans }}
                            </a>
                            <a class="btn btn-warning" href="{{ url('user_edit', {id: user.id}) }}" title="{{ 'action.edit'|trans }}">
                                {{ 'action.edit'|trans }}
                            </a>
                            {% if user != app.user %}
                                <a class="btn btn-danger" href="{{ url('user_delete', {id: user.id}) }}" title="{{ 'action.delete'|trans }}">
                                    {{ 'action.delete'|trans }}
                                </a>
                            {% endif %}
                            {% if user != app.user %}
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <form action="{{ url('user_revoke_admin', {id: user.id}) }}" method="POST" class="d-inline-block">
                                        <button type="submit" class="btn btn-outline-danger" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" title="{{ 'action.revoke_admin'|trans }}">
                                            <i class="bi bi-shield-slash"></i> {{ 'action.revoke_admin'|trans }}
                                        </button>
                                    </form>
                                {% else %}
                                    <form action="{{ url('user_grant_admin', {id: user.id}) }}" method="POST" class="d-inline-block">
                                        <button type="submit" class="btn btn-outline-success" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" title="{{ 'action.grant_admin'|trans }}">
                                            <i class="bi bi-shield-check"></i> {{ 'action.grant_admin'|trans }}
                                        </button>
                                    </form>
                                {% endif %}
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>

        <div class="mt-3">
            <a href="{{ url('task_index') }}" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> {{ 'action.back_to_tasks'|trans|default('Back to tasks') }}
            </a>
        </div>

    {% else %}
        {% include 'default/_single_alert_message.html.twig' with {
            type: 'warning',
            message: 'message.empty_list'|trans
        } %}
    {% endif %}
{% endblock %}
