{% extends 'base.html.twig' %}

{% block title %}{{ 'title.user_view'|trans }} #{{ user.id }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>{{ 'title.user_view'|trans }} #{{ user.id }}</h1>

        <dl class="row mt-4">
            <dt class="col-sm-3">{{ 'label.id'|trans }}</dt>
            <dd class="col-sm-9">{{ user.id }}</dd>

            <dt class="col-sm-3">{{ 'label.email'|trans }}</dt>
            <dd class="col-sm-9">{{ user.email }}</dd>

            <dt class="col-sm-3">{{ 'label.roles'|trans }}</dt>
            <dd class="col-sm-9">
                {% for role in user.roles %}
                    <span class="badge bg-secondary">{{ role }}</span>
                {% endfor %}
            </dd>
        </dl>

        <div class="mt-4">
            <a href="{{ url('user_index') }}" class="btn btn-outline-secondary">
                {{ 'action.back_to_list'|trans }}
            </a>
            <a href="{{ url('user_edit', {id: user.id}) }}" class="btn btn-success">
                {{ 'action.edit'|trans }}
            </a>
        </div>
    </div>
{% endblock %}
